<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.AuditTrailController"
            prefWidth="1150"
            prefHeight="680">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="15" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="Audit Trail"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

            <Label text="Immutable system action logs. Logs can be viewed but not edited or deleted."/>

            <HBox spacing="10">
                <TextField fx:id="searchAuditField"
                           promptText="Search audit logs"
                           prefWidth="320"/>

                <ComboBox fx:id="actionFilterComboBox"
                          promptText="Action"
                          prefWidth="220"/>

                <Button fx:id="refreshButton"
                        text="Refresh"
                        onAction="#handleRefresh"/>

                <Button fx:id="backButton"
                        text="Back"
                        onAction="#handleBack"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="auditTable" prefHeight="430">
            <columns>
                <TableColumn fx:id="auditIdColumn" text="ID" prefWidth="60"/>
                <TableColumn fx:id="userEmailColumn" text="User Email" prefWidth="190"/>
                <TableColumn fx:id="roleColumn" text="Role" prefWidth="130"/>
                <TableColumn fx:id="actionColumn" text="Action" prefWidth="180"/>
                <TableColumn fx:id="entityTypeColumn" text="Entity Type" prefWidth="120"/>
                <TableColumn fx:id="entityIdColumn" text="Entity ID" prefWidth="90"/>
                <TableColumn fx:id="createdAtColumn" text="Created At" prefWidth="170"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10" prefWidth="360">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Log Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TextArea fx:id="detailsArea"
                      promptText="Select a log to view details"
                      prefRowCount="18"
                      wrapText="true"
                      editable="false"/>

            <Label fx:id="errorLabel" textFill="red" wrapText="true"/>

            <Button fx:id="viewDetailsButton"
                    text="View Details"
                    onAction="#handleViewDetails"
                    maxWidth="320"/>
        </VBox>
    </right>
</BorderPane>
