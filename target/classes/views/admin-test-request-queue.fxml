<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.RequestQueueController"
            prefWidth="1100"
            prefHeight="650">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="15" right="20" bottom="10" left="20"/>
            </padding>

            <Label fx:id="pageTitleLabel"
                   text="Super Admin Test Request Queue"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

            <Label text="View customer test requests, payment status, sample status, and result status."/>

            <HBox spacing="10">
                <TextField fx:id="searchRequestField"
                           promptText="Search by customer, test, status"
                           prefWidth="280"/>

                <ComboBox fx:id="statusFilterComboBox"
                          promptText="Status"
                          prefWidth="160"/>

                <ComboBox fx:id="paymentFilterComboBox"
                          promptText="Payment"
                          prefWidth="140"/>

                <Button fx:id="refreshButton"
                        text="Refresh"
                        onAction="#handleRefresh"/>

                <Button fx:id="backButton"
                        text="Back"
                        onAction="#handleBack"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="requestsTable" prefHeight="430">
            <columns>
                <TableColumn fx:id="requestIdColumn" text="ID" prefWidth="60"/>
                <TableColumn fx:id="customerNameColumn" text="Customer" prefWidth="160"/>
                <TableColumn fx:id="testNameColumn" text="Test" prefWidth="170"/>
                <TableColumn fx:id="priceColumn" text="Price" prefWidth="90"/>
                <TableColumn fx:id="requestDateColumn" text="Requested At" prefWidth="150"/>
                <TableColumn fx:id="sampleStatusColumn" text="Sample" prefWidth="120"/>
                <TableColumn fx:id="paymentStatusColumn" text="Payment" prefWidth="110"/>
                <TableColumn fx:id="resultStatusColumn" text="Result" prefWidth="110"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10" prefWidth="330">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Request Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TextArea fx:id="requestDetailsArea"
                      promptText="Select a request"
                      prefRowCount="14"
                      wrapText="true"
                      editable="false"/>

            <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
            <Label fx:id="successLabel" textFill="green" wrapText="true"/>

            <Button fx:id="viewDetailsButton"
                    text="View Details"
                    onAction="#handleViewDetails"
                    maxWidth="290"/>

            <Button fx:id="markPaidButton"
                    text="Mark Selected as PAID"
                    onAction="#handleMarkPaid"
                    maxWidth="290"/>
        </VBox>
    </right>
</BorderPane>
