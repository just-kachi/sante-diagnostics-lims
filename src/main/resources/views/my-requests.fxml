<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.MyRequestsController"
            stylesheets="@../styles/theme.css"
            prefWidth="1280" prefHeight="780">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="My Test Requests" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="countdownLabel" text="Next ready in: —" styleClass="label-countdown"/>
            <Region prefWidth="12"/>
            <Button fx:id="backButton" text="Back" styleClass="button-secondary" onAction="#handleBack"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
                <Label text="Search:"/>
                <TextField fx:id="searchRequestField" promptText="Test or request ID" prefWidth="260"/>
                <Label text="Status:"/>
                <ComboBox fx:id="requestStatusFilterComboBox" promptText="All" prefWidth="160">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="ALL"/>
                            <String fx:value="ACTIVE"/>
                            <String fx:value="COMPLETED"/>
                            <String fx:value="CANCELLED"/>
                        </FXCollections>
                    </items>
                </ComboBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="refreshButton" text="Refresh" styleClass="button-secondary" onAction="#handleRefresh"/>
            </HBox>

            <HBox spacing="14" VBox.vgrow="ALWAYS">
                <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="My Requests" styleClass="label-section"/>
                    <TableView fx:id="myRequestsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="requestIdColumn"        text="Req ID"        prefWidth="80"/>
                            <TableColumn fx:id="testNameColumn"         text="Test"          prefWidth="200"/>
                            <TableColumn fx:id="requestDateColumn"      text="Requested"     prefWidth="140"/>
                            <TableColumn fx:id="paymentStatusColumn"    text="Payment"       prefWidth="100"/>
                            <TableColumn fx:id="sampleStatusColumn"     text="Sample Status" prefWidth="130"/>
                            <TableColumn fx:id="resultStatusColumn"     text="Result Status" prefWidth="130"/>
                            <TableColumn fx:id="estimatedReadyAtColumn" text="Estimated Ready" prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="card" spacing="10" prefWidth="340">
                    <Label text="Request Details" styleClass="label-section"/>
                    <TextArea fx:id="requestDetailsArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
                    <Button fx:id="viewDetailsButton" text="View Details" styleClass="button-secondary" onAction="#handleViewDetails"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
