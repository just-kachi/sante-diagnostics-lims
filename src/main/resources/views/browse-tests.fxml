<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.BrowseTestsController"
            stylesheets="@../styles/theme.css"
            prefWidth="1280" prefHeight="780">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Browse Available Tests" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" text="Back" styleClass="button-secondary" onAction="#handleBack"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
                <Label text="Search:"/>
                <TextField fx:id="searchTestField" promptText="Search test name" prefWidth="280"/>
                <Label text="Category:"/>
                <ComboBox fx:id="categoryFilterComboBox" promptText="All categories" prefWidth="200"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="refreshButton" text="Refresh" styleClass="button-secondary" onAction="#handleRefresh"/>
            </HBox>

            <HBox spacing="14" VBox.vgrow="ALWAYS">
                <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Available Tests" styleClass="label-section"/>
                    <TableView fx:id="testsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="testTypeIdColumn"   text="ID"            prefWidth="70"/>
                            <TableColumn fx:id="testNameColumn"     text="Test Name"     prefWidth="220"/>
                            <TableColumn fx:id="testCategoryColumn" text="Category"      prefWidth="140"/>
                            <TableColumn fx:id="priceColumn"        text="Price"         prefWidth="110"/>
                            <TableColumn fx:id="tatHoursColumn"     text="TAT (hrs)"     prefWidth="100"/>
                            <TableColumn fx:id="resultFormatColumn" text="Result Format" prefWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="card" spacing="10" prefWidth="360">
                    <Label text="Selected Test" styleClass="label-section"/>
                    <TextArea fx:id="selectedTestDetailsArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>

                    <Label fx:id="errorLabel" styleClass="label-error" wrapText="true"/>
                    <Label fx:id="successLabel" styleClass="label-success" wrapText="true"/>

                    <Button fx:id="requestSelectedTestButton" text="Request This Test"
                            styleClass="button-accent" maxWidth="Infinity"
                            onAction="#handleRequestSelectedTest"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
