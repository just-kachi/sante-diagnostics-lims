<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.RequestQueueController"
            stylesheets="@../styles/theme.css"
            prefWidth="1280" prefHeight="780">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Lab Request Queue" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" text="Back" styleClass="button-secondary" onAction="#handleBack"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
                <Label text="Search:"/>
                <TextField fx:id="searchRequestField" promptText="Customer, test, or ID" prefWidth="260"/>

                <Label text="Sample status:"/>
                <ComboBox fx:id="statusFilterComboBox" promptText="All" prefWidth="170">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="ALL"/>
                            <String fx:value="REQUESTED"/>
                            <String fx:value="COLLECTED"/>
                            <String fx:value="PROCESSING"/>
                            <String fx:value="VALIDATED"/>
                            <String fx:value="READY"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <Label text="Payment:"/>
                <ComboBox fx:id="paymentFilterComboBox" promptText="All" prefWidth="140">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="ALL"/>
                            <String fx:value="UNPAID"/>
                            <String fx:value="PAID"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="refreshButton" text="Refresh" styleClass="button-secondary" onAction="#handleRefresh"/>
            </HBox>

            <HBox spacing="14" VBox.vgrow="ALWAYS">
                <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Test Requests" styleClass="label-section"/>
                    <TableView fx:id="requestsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="requestIdColumn" text="Req ID" prefWidth="80"/>
                            <TableColumn fx:id="customerNameColumn" text="Customer" prefWidth="200"/>
                            <TableColumn fx:id="testNameColumn" text="Test" prefWidth="200"/>
                            <TableColumn fx:id="priceColumn" text="Price" prefWidth="90"/>
                            <TableColumn fx:id="requestDateColumn" text="Requested" prefWidth="150"/>
                            <TableColumn fx:id="sampleStatusColumn" text="Sample Status" prefWidth="140"/>
                            <TableColumn fx:id="paymentStatusColumn" text="Payment" prefWidth="110"/>
                            <TableColumn fx:id="resultStatusColumn" text="Result Status" prefWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="card" spacing="10" prefWidth="340">
                    <Label text="Request Details" styleClass="label-section"/>
                    <TextArea fx:id="requestDetailsArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>

                    <Label fx:id="errorLabel" styleClass="label-error" wrapText="true"/>
                    <Label fx:id="successLabel" styleClass="label-success" wrapText="true"/>

                    <HBox spacing="8">
                        <Button fx:id="viewDetailsButton" text="View Details" styleClass="button-secondary" onAction="#handleViewDetails"/>
                        <Button fx:id="markPaidButton" text="Mark Paid" styleClass="button-accent" onAction="#handleMarkPaid"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>