<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="lims.controllers.VerifyEmailController"
      alignment="CENTER"
      spacing="12"
      prefWidth="600"
      prefHeight="420">

    <padding>
        <Insets top="35" right="60" bottom="35" left="60"/>
    </padding>

    <Label text="Verify Your Email" style="-fx-font-size: 26px; -fx-font-weight: bold;"/>

    <Label fx:id="instructionLabel"
           text="Enter the verification code sent to your email."
           wrapText="true"
           maxWidth="450"/>

    <TextField fx:id="tokenField"
               promptText="Verification Code"
               maxWidth="300"/>

    <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
    <Label fx:id="successLabel" textFill="green" wrapText="true"/>

    <Button fx:id="verifyButton"
            text="Verify Email"
            onAction="#handleVerifyEmail"
            maxWidth="300"/>

    <Button fx:id="resendCodeButton"
            text="Resend Code"
            onAction="#handleResendCode"
            maxWidth="300"/>

    <Button fx:id="logoutButton"
            text="Logout"
            onAction="#handleLogout"
            maxWidth="300"/>
</VBox>
