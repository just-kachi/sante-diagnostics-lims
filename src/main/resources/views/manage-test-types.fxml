<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.ManageTestTypesController"
            stylesheets="@../styles/theme.css"
            prefWidth="1320" prefHeight="800">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Manage Test Types" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" text="Back" styleClass="button-secondary" onAction="#handleBack"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="16">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <!-- Form -->
            <VBox styleClass="form-section" spacing="10" prefWidth="420">
                <Label text="Test Type Details" styleClass="label-section"/>

                <Label text="Test name"/>
                <TextField fx:id="testNameField" promptText="e.g. Complete Blood Count"/>

                <Label text="Category"/>
                <TextField fx:id="testCategoryField" promptText="e.g. Hematology"/>

                <Label text="Price (NGN)"/>
                <TextField fx:id="priceField" promptText="0.00"/>

                <Label text="Turn-around time (hours)"/>
                <TextField fx:id="tatHoursField" promptText="e.g. 24"/>

                <Label text="Result format"/>
                <ComboBox fx:id="resultFormatComboBox" promptText="Select result format" maxWidth="Infinity">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="NUMERIC"/>
                            <String fx:value="TEXT"/>
                            <String fx:value="PDF"/>
                            <String fx:value="IMAGE"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <Label text="Description"/>
                <TextArea fx:id="descriptionArea" promptText="Optional description" prefRowCount="4" wrapText="true"/>

                <Label fx:id="errorLabel" styleClass="label-error" wrapText="true"/>
                <Label fx:id="successLabel" styleClass="label-success" wrapText="true"/>

                <HBox spacing="8">
                    <Button fx:id="addTestTypeButton" text="Add" onAction="#handleAddTestType"/>
                    <Button fx:id="updateTestTypeButton" text="Update" styleClass="button-accent" onAction="#handleUpdateTestType"/>
                    <Button fx:id="deleteTestTypeButton" text="Delete" styleClass="button-danger" onAction="#handleDeleteTestType"/>
                    <Button fx:id="clearFormButton" text="Clear" styleClass="button-secondary" onAction="#handleClearForm"/>
                </HBox>
            </VBox>

            <!-- Table -->
            <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Available Tests" styleClass="label-section"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchTestTypeField" promptText="Search by name or category" prefWidth="260"/>
                    <Button fx:id="refreshButton" text="Refresh" styleClass="button-secondary" onAction="#handleRefresh"/>
                </HBox>

                <TableView fx:id="testTypesTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="testTypeIdColumn"   text="ID"           prefWidth="60"/>
                        <TableColumn fx:id="testNameColumn"     text="Test Name"    prefWidth="200"/>
                        <TableColumn fx:id="testCategoryColumn" text="Category"     prefWidth="140"/>
                        <TableColumn fx:id="priceColumn"        text="Price"        prefWidth="100"/>
                        <TableColumn fx:id="tatHoursColumn"     text="TAT (hrs)"    prefWidth="100"/>
                        <TableColumn fx:id="resultFormatColumn" text="Result Format" prefWidth="130"/>
                        <TableColumn fx:id="descriptionColumn"  text="Description"  prefWidth="240"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </center>
</BorderPane>
