<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.ResultUploadController"
            stylesheets="@../styles/theme.css"
            prefWidth="1280" prefHeight="800">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Upload Test Result" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" text="Back" styleClass="button-secondary" onAction="#handleBack"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
                <Label text="Search:"/>
                <TextField fx:id="searchResultField" promptText="Customer, test, or result ID" prefWidth="280"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="refreshButton" text="Refresh" styleClass="button-secondary" onAction="#handleRefresh"/>
            </HBox>

            <HBox spacing="14" VBox.vgrow="ALWAYS">
                <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Results Awaiting Upload" styleClass="label-section"/>

                    <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="resultIdColumn" text="Result ID" prefWidth="90"/>
                            <TableColumn fx:id="requestIdColumn" text="Req ID" prefWidth="80"/>
                            <TableColumn fx:id="customerNameColumn" text="Customer" prefWidth="170"/>
                            <TableColumn fx:id="testNameColumn" text="Test" prefWidth="180"/>
                            <TableColumn fx:id="resultFormatColumn" text="Format" prefWidth="100"/>
                            <TableColumn fx:id="paymentStatusColumn" text="Payment" prefWidth="100"/>
                            <TableColumn fx:id="sampleStatusColumn" text="Sample" prefWidth="110"/>
                            <TableColumn fx:id="resultStatusColumn" text="Result" prefWidth="110"/>
                            <TableColumn fx:id="uploadedAtColumn" text="Uploaded At" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="card" spacing="10" prefWidth="380">
                    <Label text="Result Value" styleClass="label-section"/>
                    <Label text="For NUMERIC or TEXT results, type here. For PDF/IMAGE results, choose a file."
                           styleClass="label-muted" wrapText="true"/>

                    <Label fx:id="resultDetailsLabel"
                           text="Select a result to view details."
                           styleClass="label-muted"
                           wrapText="true"/>

                    <TextArea fx:id="resultValueArea"
                              promptText="Enter result value, range, or notes"
                              prefRowCount="6"
                              wrapText="true"/>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Button fx:id="chooseFileButton"
                                text="Choose File…"
                                styleClass="button-secondary"
                                onAction="#handleChooseFile"/>

                        <Label fx:id="selectedFileLabel"
                               text="No file selected"
                               styleClass="label-muted"
                               wrapText="true"/>
                    </HBox>

                    <Label fx:id="errorLabel" styleClass="label-error" wrapText="true"/>
                    <Label fx:id="successLabel" styleClass="label-success" wrapText="true"/>

                    <Region VBox.vgrow="ALWAYS"/>

                    <HBox spacing="8">
                        <Button fx:id="uploadResultButton"
                                text="Upload Result"
                                onAction="#handleUploadResult"/>

                        <Button fx:id="clearButton"
                                text="Clear"
                                styleClass="button-secondary"
                                onAction="#handleClear"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>