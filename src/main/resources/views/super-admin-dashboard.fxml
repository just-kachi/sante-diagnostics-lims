<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.SuperAdminDashboardController"
            stylesheets="@../styles/theme.css"
            prefWidth="1200" prefHeight="760">

    <!-- Sidebar -->
    <left>
        <VBox spacing="6" styleClass="sidebar" prefWidth="240">
            <Label text="Sante Diagnostics" styleClass="label-brand"/>
            <Label text="SUPER ADMIN"/>
            <Region prefHeight="20"/>
            <Button text="Dashboard" styleClass="sidebar-button,sidebar-button-active" maxWidth="Infinity"/>
            <Button fx:id="manageUsersButton" text="Manage Users"
                    styleClass="sidebar-button" maxWidth="Infinity" onAction="#goToManageUsers"/>
            <Button fx:id="manageTestTypesButton" text="Manage Test Types"
                    styleClass="sidebar-button" maxWidth="Infinity" onAction="#goToManageTestTypes"/>
            <Button fx:id="adminRequestQueueButton" text="Request Queue"
                    styleClass="sidebar-button" maxWidth="Infinity" onAction="#goToAdminRequestQueue"/>
            <Button fx:id="auditTrailButton" text="Audit Trail"
                    styleClass="sidebar-button" maxWidth="Infinity" onAction="#goToAuditTrail"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="logoutButton" text="Logout"
                    styleClass="sidebar-button" maxWidth="Infinity" onAction="#handleLogout"/>
        </VBox>
    </left>

    <!-- Top bar -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label fx:id="welcomeLabel" text="Welcome, Administrator" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Super Admin Console" styleClass="label-muted"/>
        </HBox>
    </top>

    <!-- Stats -->
    <center>
        <VBox spacing="18">
            <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>

            <Label text="System Overview" styleClass="label-section"/>

            <HBox spacing="16">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Total Users" styleClass="label-stat-caption"/>
                    <Label fx:id="totalUsersLabel" text="0" styleClass="label-stat-value"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Pending Requests" styleClass="label-stat-caption"/>
                    <Label fx:id="pendingRequestsLabel" text="0" styleClass="label-stat-value"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Paid Requests" styleClass="label-stat-caption"/>
                    <Label fx:id="paidRequestsLabel" text="0" styleClass="label-stat-value"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Validated Results" styleClass="label-stat-caption"/>
                    <Label fx:id="validatedResultsLabel" text="0" styleClass="label-stat-value"/>
                </VBox>
            </HBox>

            <VBox styleClass="card" spacing="10">
                <Label text="Quick Actions" styleClass="label-section"/>
                <HBox spacing="10">
                    <Button text="Manage Users" onAction="#goToManageUsers"/>
                    <Button text="Manage Test Types" styleClass="button-accent" onAction="#goToManageTestTypes"/>
                    <Button text="Open Request Queue" styleClass="button-secondary" onAction="#goToAdminRequestQueue"/>
                    <Button text="View Audit Trail" styleClass="button-secondary" onAction="#goToAuditTrail"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
