<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.SampleTrackingController"
            stylesheets="@../styles/theme.css"
            prefWidth="1280" prefHeight="780">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Sample Tracking" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" text="Back" styleClass="button-secondary" onAction="#handleBack"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
                <Label text="Search:"/>
                <TextField fx:id="searchSampleField" promptText="Customer, test, or ID" prefWidth="260"/>

                <Label text="Filter status:"/>
                <ComboBox fx:id="filterStatusComboBox" promptText="All" prefWidth="170">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="ALL"/>
                            <String fx:value="REQUESTED"/>
                            <String fx:value="COLLECTED"/>
                            <String fx:value="PROCESSING"/>
                            <String fx:value="VALIDATED"/>
                            <String fx:value="READY"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <Label text="Set status:"/>
                <ComboBox fx:id="sampleStatusComboBox" promptText="Select status" prefWidth="180">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="REQUESTED"/>
                            <String fx:value="COLLECTED"/>
                            <String fx:value="PROCESSING"/>
                            <String fx:value="VALIDATED"/>
                            <String fx:value="READY"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <Button fx:id="updateStatusButton" text="Update Status" styleClass="button-accent" onAction="#handleUpdateStatus"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="refreshButton" text="Refresh" styleClass="button-secondary" onAction="#handleRefresh"/>
            </HBox>

            <HBox spacing="14" VBox.vgrow="ALWAYS">
                <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Sample Lifecycle" styleClass="label-section"/>

                    <TableView fx:id="samplesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="sampleIdColumn" text="Sample ID" prefWidth="100"/>
                            <TableColumn fx:id="requestIdColumn" text="Req ID" prefWidth="80"/>
                            <TableColumn fx:id="customerNameColumn" text="Customer" prefWidth="180"/>
                            <TableColumn fx:id="testNameColumn" text="Test" prefWidth="180"/>
                            <TableColumn fx:id="paymentStatusColumn" text="Payment" prefWidth="100"/>
                            <TableColumn fx:id="sampleStatusColumn" text="Sample Status" prefWidth="130"/>
                            <TableColumn fx:id="resultStatusColumn" text="Result Status" prefWidth="130"/>
                            <TableColumn fx:id="updatedAtColumn" text="Updated At" prefWidth="170"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="card" spacing="10" prefWidth="340">
                    <Label text="Sample Details" styleClass="label-section"/>

                    <TextArea fx:id="sampleDetailsArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>

                    <Label fx:id="errorLabel" styleClass="label-error" wrapText="true"/>
                    <Label fx:id="successLabel" styleClass="label-success" wrapText="true"/>

                    <Button fx:id="viewDetailsButton" text="View Details" styleClass="button-secondary" onAction="#handleViewDetails"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>