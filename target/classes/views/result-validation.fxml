<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.ResultValidationController"
            prefWidth="1180"
            prefHeight="700">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="15" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="Result Validation"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

            <Label text="Validate uploaded results before they become visible to customers."/>

            <HBox spacing="10">
                <TextField fx:id="searchResultField"
                           promptText="Search by customer, test, status, request ID"
                           prefWidth="360"/>

                <Button fx:id="refreshButton"
                        text="Refresh"
                        onAction="#handleRefresh"/>

                <Button fx:id="backButton"
                        text="Back"
                        onAction="#handleBack"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="resultsTable" prefHeight="430">
            <columns>
                <TableColumn fx:id="resultIdColumn" text="Result ID" prefWidth="80"/>
                <TableColumn fx:id="requestIdColumn" text="Request ID" prefWidth="90"/>
                <TableColumn fx:id="customerNameColumn" text="Customer" prefWidth="150"/>
                <TableColumn fx:id="testNameColumn" text="Test" prefWidth="160"/>
                <TableColumn fx:id="resultFormatColumn" text="Format" prefWidth="90"/>
                <TableColumn fx:id="paymentStatusColumn" text="Payment" prefWidth="90"/>
                <TableColumn fx:id="sampleStatusColumn" text="Sample" prefWidth="110"/>
                <TableColumn fx:id="resultStatusColumn" text="Result" prefWidth="110"/>
                <TableColumn fx:id="uploadedAtColumn" text="Uploaded At" prefWidth="145"/>
                <TableColumn fx:id="validatedAtColumn" text="Validated At" prefWidth="145"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10" prefWidth="370">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Result Preview" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TextArea fx:id="resultPreviewArea"
                      promptText="Select a result to preview"
                      prefRowCount="14"
                      wrapText="true"
                      editable="false"/>

            <TextArea fx:id="rejectionReasonArea"
                      promptText="Reason for rejection, if rejecting"
                      prefRowCount="4"
                      wrapText="true"/>

            <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
            <Label fx:id="successLabel" textFill="green" wrapText="true"/>

            <Button fx:id="validateResultButton"
                    text="Validate Result"
                    onAction="#handleValidateResult"
                    maxWidth="330"/>

            <Button fx:id="rejectResultButton"
                    text="Reject Result"
                    onAction="#handleRejectResult"
                    maxWidth="330"/>

            <Button fx:id="viewResultButton"
                    text="View Result"
                    onAction="#handleViewResult"
                    maxWidth="330"/>
        </VBox>
    </right>
</BorderPane>
