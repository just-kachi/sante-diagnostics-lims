<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="lims.controllers.SuperAdminDashboardController"
      alignment="CENTER"
      spacing="15"
      prefWidth="700"
      prefHeight="500">

    <padding>
        <Insets top="40" right="60" bottom="40" left="60"/>
    </padding>

    <Label text="Super Admin Dashboard" style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
    <Label fx:id="welcomeLabel" text="Welcome, Super Admin"/>

    <Label text="Governance and Configuration" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <Button fx:id="manageTestTypesButton"
            text="Manage Test Types"
            onAction="#goToManageTestTypes"
            maxWidth="300"/>

    <Button fx:id="adminRequestQueueButton"
            text="Test Request Queue"
            onAction="#goToAdminRequestQueue"
            maxWidth="300"/>
    
    <Button fx:id="manageUsersButton"
        text="Manage Users"
        onAction="#goToManageUsers"
        maxWidth="300"/>
    
    <Button fx:id="auditTrailButton"
        text="Audit Trail"
        onAction="#goToAuditTrail"
        maxWidth="300"/>

    <Button fx:id="logoutButton"
            text="Logout"
            onAction="#handleLogout"
            maxWidth="300"/>
</VBox>