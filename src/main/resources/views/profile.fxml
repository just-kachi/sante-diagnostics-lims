<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.ProfileController"
            stylesheets="@../styles/theme.css"
            prefWidth="900" prefHeight="600">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Profile" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" text="Back" styleClass="button-secondary" onAction="#handleBack"/>
            <Button fx:id="logoutButton" text="Logout" styleClass="button-danger" onAction="#handleLogout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" alignment="TOP_CENTER">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <VBox styleClass="card" spacing="14" maxWidth="640">
                <Label text="Account Information" styleClass="label-section"/>
                <Separator/>

                <GridPane hgap="16" vgap="12">
                    <Label text="Full name:"        styleClass="label-muted" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="fullNameLabel"    text="—"                 GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Email:"            styleClass="label-muted" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="emailLabel"       text="—"                 GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Role:"             styleClass="label-muted" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="roleLabel"        text="—"                 GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Email verified:"   styleClass="label-muted" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label fx:id="emailVerifiedLabel" text="—"               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Member since:"     styleClass="label-muted" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <Label fx:id="createdAtLabel"   text="—"                 GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                </GridPane>
            </VBox>
        </VBox>
    </center>
</BorderPane>
