<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="lims.controllers.LabAttendantDashboardController"
      alignment="CENTER"
      spacing="15"
      prefWidth="700"
      prefHeight="600">

    <padding>
        <Insets top="40" right="60" bottom="40" left="60"/>
    </padding>

    <Label text="Lab Attendant Dashboard" style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
    <Label fx:id="welcomeLabel" text="Welcome, Lab Attendant"/>

    <Label text="Operational Fulfillment" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <Button fx:id="labRequestQueueButton"
            text="Test Request Queue"
            onAction="#goToLabRequestQueue"
            maxWidth="300"/>

    <Button fx:id="sampleTrackingButton"
            text="Sample Tracking"
            onAction="#goToSampleTracking"
            maxWidth="300"/>

    <Button fx:id="resultUploadButton"
            text="Result Upload"
            onAction="#goToResultUpload"
            maxWidth="300"/>

    <Button fx:id="resultValidationButton"
            text="Result Validation"
            onAction="#goToResultValidation"
            maxWidth="300"/>
    
    <Button fx:id="manageUsersButton"
        text="Create Customer Account"
        onAction="#goToManageUsers"
        maxWidth="300"/>

    <Button fx:id="logoutButton"
            text="Logout"
            onAction="#handleLogout"
            maxWidth="300"/>
</VBox>