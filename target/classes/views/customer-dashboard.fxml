<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="lims.controllers.CustomerDashboardController"
      alignment="CENTER"
      spacing="15"
      prefWidth="700"
      prefHeight="560">

    <padding>
        <Insets top="40" right="60" bottom="40" left="60"/>
    </padding>

    <Label text="Customer Dashboard" style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
    <Label fx:id="welcomeLabel" text="Welcome, Customer"/>

    <Label text="Customer Transparency and Access" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <Button fx:id="browseTestsButton"
            text="Browse Available Tests"
            onAction="#goToBrowseTests"
            maxWidth="300"/>

    <Button fx:id="myRequestsButton"
            text="My Requests"
            onAction="#goToMyRequests"
            maxWidth="300"/>

    <Button fx:id="customerResultsButton"
            text="Result Vault"
            onAction="#goToCustomerResults"
            maxWidth="300"/>

    <Button fx:id="logoutButton"
            text="Logout"
            onAction="#handleLogout"
            maxWidth="300"/>
</VBox>