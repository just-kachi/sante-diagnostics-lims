<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.ManageUsersController"
            stylesheets="@../styles/theme.css"
            prefWidth="1280" prefHeight="780">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Manage Users" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" text="Back" styleClass="button-secondary" onAction="#handleBack"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="16">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <!-- Create user form -->
            <VBox styleClass="form-section" spacing="10" prefWidth="380">
                <Label text="Create a New User" styleClass="label-section"/>

                <Label text="Full name"/>
                <TextField fx:id="fullNameField" promptText="Jane Doe"/>

                <Label text="Email"/>
                <TextField fx:id="emailField" promptText="user@example.com"/>

                <Label text="Temporary password"/>
                <PasswordField fx:id="temporaryPasswordField" promptText="One-time password"/>

                <Label text="Role"/>
                <ComboBox fx:id="roleComboBox" promptText="Select role" maxWidth="Infinity">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="LAB_ATTENDANT"/>
                            <String fx:value="CUSTOMER"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <Label fx:id="errorLabel" styleClass="label-error" wrapText="true"/>
                <Label fx:id="successLabel" styleClass="label-success" wrapText="true"/>

                <HBox spacing="8">
                    <Button fx:id="createUserButton" text="Create User" onAction="#handleCreateUser"/>
                    <Button fx:id="clearFormButton" text="Clear" styleClass="button-secondary" onAction="#handleRefresh"/>
                </HBox>
            </VBox>

            <!-- Users table -->
            <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Existing Users" styleClass="label-section"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchUserField" promptText="Search by name or email" prefWidth="260"/>
                    <Button fx:id="refreshUsersButton" text="Refresh" styleClass="button-secondary" onAction="#handleRefresh"/>
                </HBox>

                <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="userIdColumn"        text="ID"           prefWidth="60"/>
                        <TableColumn fx:id="fullNameColumn"      text="Full Name"    prefWidth="180"/>
                        <TableColumn fx:id="emailColumn"         text="Email"        prefWidth="220"/>
                        <TableColumn fx:id="roleColumn"          text="Role"         prefWidth="140"/>
                        <TableColumn fx:id="emailVerifiedColumn" text="Email Verified" prefWidth="120"/>
                        <TableColumn fx:id="forcePasswordChangeColumn"   text="Force Change" prefWidth="120"/>
                        <TableColumn fx:id="createdAtColumn"     text="Created At"   prefWidth="160"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </center>
</BorderPane>
