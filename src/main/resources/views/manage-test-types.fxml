<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.ManageTestTypesController"
            prefWidth="1000"
            prefHeight="650">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="15" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="Manage Test Types" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Create and configure laboratory tests, prices, turnaround times, and result formats."/>

            <HBox spacing="10">
                <TextField fx:id="searchTestTypeField"
                           promptText="Search by name, category, format, or price"
                           prefWidth="420"/>

                <Button fx:id="refreshButton"
                        text="Refresh"
                        onAction="#handleRefresh"/>

                <Button fx:id="backButton"
                        text="Back"
                        onAction="#handleBack"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="testTypesTable" prefHeight="400">
            <columns>
                <TableColumn fx:id="testTypeIdColumn" text="ID" prefWidth="60"/>
                <TableColumn fx:id="testNameColumn" text="Name" prefWidth="160"/>
                <TableColumn fx:id="testCategoryColumn" text="Category" prefWidth="120"/>
                <TableColumn fx:id="priceColumn" text="Price" prefWidth="100"/>
                <TableColumn fx:id="tatHoursColumn" text="TAT Hours" prefWidth="100"/>
                <TableColumn fx:id="resultFormatColumn" text="Format" prefWidth="100"/>
                <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="250"/>
                <TableColumn fx:id="activeColumn" text="Active" prefWidth="80"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10" prefWidth="320">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Test Type Form" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TextField fx:id="testNameField" promptText="Test name"/>
            <TextField fx:id="testCategoryField" promptText="Category e.g. Blood, Imaging"/>
            <TextField fx:id="priceField" promptText="Price e.g. 5000"/>
            <TextField fx:id="tatHoursField" promptText="TAT in hours e.g. 24"/>

            <ComboBox fx:id="resultFormatComboBox" promptText="Result format" prefWidth="280"/>

            <TextArea fx:id="descriptionArea"
                      promptText="Description"
                      prefRowCount="5"
                      wrapText="true"/>

            <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
            <Label fx:id="successLabel" textFill="green" wrapText="true"/>

            <Button fx:id="addTestTypeButton"
                    text="Add Test Type"
                    onAction="#handleAddTestType"
                    maxWidth="280"/>

            <Button fx:id="updateTestTypeButton"
                    text="Update Selected"
                    onAction="#handleUpdateTestType"
                    maxWidth="280"/>

            <Button fx:id="deleteTestTypeButton"
                    text="Deactivate Selected"
                    onAction="#handleDeleteTestType"
                    maxWidth="280"/>

            <Button fx:id="clearFormButton"
                    text="Clear Form"
                    onAction="#handleClearForm"
                    maxWidth="280"/>
        </VBox>
    </right>
</BorderPane>