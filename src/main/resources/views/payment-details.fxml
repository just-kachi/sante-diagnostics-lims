<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="lims.controllers.PaymentDetailsController"
           stylesheets="@../styles/theme.css"
           prefWidth="900" prefHeight="640">

    <VBox alignment="TOP_CENTER" spacing="14" maxWidth="640" styleClass="card">
        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

        <Label text="Bank Payment Instructions" styleClass="label-title"/>
        <Label text="Please transfer the exact amount to the bank account below, or use Pay Now for demo payment confirmation."
               styleClass="label-muted" wrapText="true"/>

        <Separator/>

        <GridPane hgap="14" vgap="10">
            <Label text="Request ID:" styleClass="label-muted" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Label fx:id="requestIdLabel" text="—" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Test:" styleClass="label-muted" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <Label fx:id="testNameLabel" text="—" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Amount:" styleClass="label-muted" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <Label fx:id="amountLabel" text="—" styleClass="label-stat-value" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Bank Name:" styleClass="label-muted" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <Label fx:id="bankNameLabel" text="PAU Demo Bank" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Account Number:" styleClass="label-muted" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <Label fx:id="accountNumberLabel" text="0123456789" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Account Name:" styleClass="label-muted" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <Label fx:id="accountNameLabel" text="Sante Diagnostics Ltd." GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label text="Payment Status:" styleClass="label-muted" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <Label fx:id="paymentStatusLabel" text="UNPAID" styleClass="pill-warning" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
        </GridPane>

        <Separator/>

        <Label fx:id="instructionLabel"
               text="You can pay now for demo purposes, or pay later and return from My Requests."
               styleClass="label-muted" wrapText="true"/>

        <Label fx:id="messageLabel"
               text=""
               styleClass="label-success"
               wrapText="true"/>

        <Region prefHeight="8"/>

        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="payNowButton"
                    text="Pay Now"
                    styleClass="button-accent"
                    onAction="#handlePayNow"/>

            <Button fx:id="payLaterButton"
                    text="Pay Later"
                    styleClass="button-secondary"
                    onAction="#handlePayLater"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="goToDashboardButton"
                    text="Go to Dashboard"
                    styleClass="button-secondary"
                    onAction="#goToDashboard"/>

            <Button fx:id="goToMyRequestsButton"
                    text="View My Requests"
                    onAction="#goToMyRequests"/>
        </HBox>
    </VBox>
</StackPane>