<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.CustomerDashboardController"
            stylesheets="@../styles/theme.css"
            prefWidth="1200" prefHeight="760">

    <left>
        <VBox spacing="6" styleClass="sidebar" prefWidth="240">
            <Label text="Sante Diagnostics" styleClass="label-brand"/>
            <Label text="CUSTOMER"/>
            <Region prefHeight="20"/>

            <Button text="Dashboard"
                    styleClass="sidebar-button,sidebar-button-active"
                    maxWidth="Infinity"/>

            <Button fx:id="browseTestsButton"
                    text="Browse Tests"
                    styleClass="sidebar-button"
                    maxWidth="Infinity"
                    onAction="#goToBrowseTests"/>

            <Button fx:id="myRequestsButton"
                    text="My Requests"
                    styleClass="sidebar-button"
                    maxWidth="Infinity"
                    onAction="#goToMyRequests"/>

            <Button fx:id="customerResultsButton"
                    text="My Results"
                    styleClass="sidebar-button"
                    maxWidth="Infinity"
                    onAction="#goToCustomerResults"/>

            <Button fx:id="profileButton"
                    text="Profile"
                    styleClass="sidebar-button"
                    maxWidth="Infinity"
                    onAction="#goToProfile"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="logoutButton"
                    text="Logout"
                    styleClass="sidebar-button"
                    maxWidth="Infinity"
                    onAction="#handleLogout"/>
        </VBox>
    </left>

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label fx:id="welcomeLabel" text="Welcome" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Patient Portal" styleClass="label-muted"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18">
            <padding>
                <Insets top="22" right="22" bottom="22" left="22"/>
            </padding>

            <HBox spacing="16">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Active Requests" styleClass="label-stat-caption"/>
                    <Label fx:id="activeRequestsLabel" text="0" styleClass="label-stat-value"/>
                </VBox>

                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Ready Results" styleClass="label-stat-caption"/>
                    <Label fx:id="readyResultsLabel" text="0" styleClass="label-stat-value"/>
                </VBox>

                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Past Results" styleClass="label-stat-caption"/>
                    <Label fx:id="pastResultsLabel" text="0" styleClass="label-stat-value"/>
                </VBox>
            </HBox>

            <VBox styleClass="card" spacing="8">
                <Label text="Next Result" styleClass="label-section"/>
                <Label fx:id="nextResultCountdownLabel"
                       text="No active request"
                       styleClass="label-countdown"/>
                <Label text="Countdown is based on estimated turn-around time."
                       styleClass="label-muted"/>
            </VBox>

            <VBox styleClass="card" spacing="10">
                <Label text="Quick Actions" styleClass="label-section"/>

                <HBox spacing="10">
                    <Button text="Browse Tests"
                            onAction="#goToBrowseTests"/>

                    <Button text="My Requests"
                            styleClass="button-accent"
                            onAction="#goToMyRequests"/>

                    <Button text="My Results"
                            styleClass="button-secondary"
                            onAction="#goToCustomerResults"/>

                    <Button text="Profile"
                            styleClass="button-secondary"
                            onAction="#goToProfile"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>