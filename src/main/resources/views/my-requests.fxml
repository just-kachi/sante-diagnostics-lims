<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.MyRequestsController"
            prefWidth="1050"
            prefHeight="650">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="15" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="My Test Requests" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="View your test requests, payment status, sample progress, and result readiness."/>

            <HBox spacing="10">
                <TextField fx:id="searchRequestField"
                           promptText="Search requests"
                           prefWidth="280"/>

                <ComboBox fx:id="requestStatusFilterComboBox"
                          promptText="Filter"
                          prefWidth="160"/>

                <Button fx:id="refreshButton"
                        text="Refresh"
                        onAction="#handleRefresh"/>

                <Button fx:id="backButton"
                        text="Back"
                        onAction="#handleBack"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="myRequestsTable" prefHeight="420">
            <columns>
                <TableColumn fx:id="requestIdColumn" text="Request ID" prefWidth="90"/>
                <TableColumn fx:id="testNameColumn" text="Test Name" prefWidth="180"/>
                <TableColumn fx:id="requestDateColumn" text="Requested At" prefWidth="150"/>
                <TableColumn fx:id="paymentStatusColumn" text="Payment" prefWidth="100"/>
                <TableColumn fx:id="sampleStatusColumn" text="Sample" prefWidth="120"/>
                <TableColumn fx:id="resultStatusColumn" text="Result" prefWidth="120"/>
                <TableColumn fx:id="estimatedReadyAtColumn" text="Estimated Ready" prefWidth="160"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10" prefWidth="330">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Request Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TextArea fx:id="requestDetailsArea"
                      promptText="Select a request to view details"
                      prefRowCount="14"
                      wrapText="true"
                      editable="false"/>

            <Label fx:id="countdownLabel"
                   text="Countdown: Select a request to view time remaining."
                   wrapText="true"/>

            <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
            <Label fx:id="successLabel" textFill="green" wrapText="true"/>

            <Button fx:id="viewDetailsButton"
                    text="View Details"
                    onAction="#handleViewDetails"
                    maxWidth="290"/>

            <Button fx:id="viewPaymentDetailsButton"
                    text="View / Pay Now"
                    onAction="#handleViewPaymentDetails"
                    maxWidth="290"/>
        </VBox>
    </right>
</BorderPane>
