<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.CustomerResultsController"
            prefWidth="1050"
            prefHeight="680">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="15" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="Result Vault"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

            <Label text="View your validated laboratory results and open attached PDF reports or medical images."/>

            <HBox spacing="10">
                <TextField fx:id="searchResultField"
                           promptText="Search by test, format, status, request ID"
                           prefWidth="360"/>

                <Button fx:id="refreshButton"
                        text="Refresh"
                        onAction="#handleRefresh"/>

                <Button fx:id="backButton"
                        text="Back"
                        onAction="#handleBack"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="resultsTable" prefHeight="430">
            <columns>
                <TableColumn fx:id="resultIdColumn" text="Result ID" prefWidth="90"/>
                <TableColumn fx:id="requestIdColumn" text="Request ID" prefWidth="100"/>
                <TableColumn fx:id="testNameColumn" text="Test Name" prefWidth="220"/>
                <TableColumn fx:id="resultFormatColumn" text="Format" prefWidth="110"/>
                <TableColumn fx:id="resultStatusColumn" text="Status" prefWidth="120"/>
                <TableColumn fx:id="validatedAtColumn" text="Validated At" prefWidth="170"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10" prefWidth="360">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Result Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TextArea fx:id="resultSummaryArea"
                      promptText="Select a result to view details"
                      prefRowCount="14"
                      wrapText="true"
                      editable="false"/>

            <Label text="Attached Result Files" style="-fx-font-weight: bold;"/>

            <ComboBox fx:id="resultFileComboBox"
                      promptText="Select attached PDF/image"
                      prefWidth="320"/>

            <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
            <Label fx:id="successLabel" textFill="green" wrapText="true"/>

            <Button fx:id="viewResultButton"
                    text="View Result Details"
                    onAction="#handleViewResult"
                    maxWidth="320"/>

            <Button fx:id="openFileButton"
                    text="Open Attached File"
                    onAction="#handleOpenFile"
                    maxWidth="320"/>
        </VBox>
    </right>
</BorderPane>
