<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.ResultViewerController"
            stylesheets="@../styles/theme.css"
            prefWidth="980" prefHeight="720">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Result Viewer" styleClass="label-section"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" text="Back" styleClass="button-secondary" onAction="#handleBack"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <VBox styleClass="card" spacing="10">
                <GridPane hgap="14" vgap="8">
                    <Label text="Test:"          styleClass="label-muted" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="testNameLabel" text="—"                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Status:"        styleClass="label-muted" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="resultStatusLabel" text="—" styleClass="pill-info" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Validated at:"  styleClass="label-muted" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="validatedAtLabel" text="—"              GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="File:"          styleClass="label-muted" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label fx:id="filePathLabel" text="—"                 GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                </GridPane>
            </VBox>

            <Separator/>

            <HBox spacing="14" VBox.vgrow="ALWAYS">
                <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Text / Numeric Result" styleClass="label-section"/>
                    <TextArea fx:id="resultTextArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
                </VBox>

                <VBox styleClass="card" spacing="6" prefWidth="380">
                    <Label text="Image Preview" styleClass="label-section"/>
                    <ImageView fx:id="imagePreview" fitWidth="340" fitHeight="340" preserveRatio="true"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="openFileButton" text="Open File" styleClass="button-secondary" onAction="#handleOpenFile"/>
                <Button fx:id="downloadFileButton" text="Download File" styleClass="button-accent" onAction="#handleDownloadFile"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
